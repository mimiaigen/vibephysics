# Include documentation
include README.md
include LICENSE
include CHANGELOG.md

# Include package data
recursive-include src/vibephysics *.md
recursive-include src/vibephysics/mapping/configs *.yaml
recursive-include src/vibephysics/feedforward/configs *.yaml

# Exclude build artifacts
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude .DS_Store
